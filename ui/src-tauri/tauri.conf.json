{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Meeting Buddy",
  "version": "0.1.0",
  "identifier": "com.meetingbuddy.overlay",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build-frontend",
    "beforeDevCommand": "npm run build-frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "AudioCapture",
      "meeting-buddy-backend",
      "MeetingBuddySettings",
      "MeetingBuddyHUD"
    ]
  }
}
