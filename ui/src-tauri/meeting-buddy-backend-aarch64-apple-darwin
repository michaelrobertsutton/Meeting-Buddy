#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# --- Project root (must resolve before venv lookup) ---
if [ -z "${MEETINGBUDDY_PROJECT_ROOT:-}" ]; then
    if [[ "$SCRIPT_DIR" == *"/Contents/MacOS"* ]]; then
        APP_BUNDLE="$SCRIPT_DIR/../.."
        CANDIDATE="$(cd "$APP_BUNDLE/../../../../../../.." 2>/dev/null && pwd)" || CANDIDATE=""
        if [ -n "$CANDIDATE" ] && [ -f "$CANDIDATE/backend/main.py" ]; then
            export MEETINGBUDDY_PROJECT_ROOT="$CANDIDATE"
        fi
    else
        # Dev mode: walk up from SCRIPT_DIR until we find backend/main.py or hit filesystem root
        WALK="$SCRIPT_DIR"
        while true; do
            if [ -f "$WALK/backend/main.py" ]; then
                export MEETINGBUDDY_PROJECT_ROOT="$WALK"
                break
            fi
            NEXT="$(cd "$WALK/.." && pwd)"
            [ "$NEXT" = "$WALK" ] && break
            WALK="$NEXT"
        done
    fi
fi

# --- Venv resolution (priority order for distribution + dev) ---
if [ -n "${MEETINGBUDDY_VENV:-}" ] && [ -d "$MEETINGBUDDY_VENV" ]; then
    VENV="$MEETINGBUDDY_VENV"
elif [ -d "$HOME/.meeting-buddy/venv" ]; then
    VENV="$HOME/.meeting-buddy/venv"
elif [ -d "$SCRIPT_DIR/../Resources/venv" ]; then
    VENV="$SCRIPT_DIR/../Resources/venv"
elif [ -n "${MEETINGBUDDY_PROJECT_ROOT:-}" ] && [ -d "$MEETINGBUDDY_PROJECT_ROOT/.venv" ]; then
    VENV="$MEETINGBUDDY_PROJECT_ROOT/.venv"
else
    echo "ERROR: No Python venv found." >&2
    echo "Run: bash scripts/install.sh" >&2
    exit 1
fi

source "$VENV/bin/activate"

# --- PYTHONPATH for backend/ and ingest/ ---
if [ -n "${MEETINGBUDDY_PROJECT_ROOT:-}" ]; then
    export PYTHONPATH="${MEETINGBUDDY_PROJECT_ROOT}:${PYTHONPATH:-}"
elif [ -d "$SCRIPT_DIR/../Resources/src" ]; then
    export PYTHONPATH="$SCRIPT_DIR/../Resources/src:${PYTHONPATH:-}"
fi

# --- AudioCapture binary ---
if [ -n "${MEETINGBUDDY_AUDIO_BINARY:-}" ]; then
    : # already set
elif [[ "$SCRIPT_DIR" == *"/Contents/MacOS"* ]]; then
    export MEETINGBUDDY_AUDIO_BINARY="$SCRIPT_DIR/AudioCapture"
else
    ROOT="${MEETINGBUDDY_PROJECT_ROOT:-$(cd "$SCRIPT_DIR/../.." && pwd)}"
    export MEETINGBUDDY_AUDIO_BINARY="$ROOT/audio-capture/.build/release/AudioCapture"
fi

# --- Port pre-check: evict any stale backend holding port 8765 ---
STALE_PIDS=$(lsof -ti tcp:8765 2>/dev/null || true)
if [ -n "$STALE_PIDS" ]; then
    echo "[sidecar] Port 8765 in use (pids: $STALE_PIDS) — killing stale process..." >&2
    echo "$STALE_PIDS" | xargs kill -TERM 2>/dev/null || true
    # Wait up to 3s for the port to clear
    for i in 1 2 3; do
        sleep 1
        STILL=$(lsof -ti tcp:8765 2>/dev/null || true)
        [ -z "$STILL" ] && break
        if [ "$i" = "3" ]; then
            echo "$STILL" | xargs kill -KILL 2>/dev/null || true
        fi
    done
fi

exec python -m backend.main "$@"
