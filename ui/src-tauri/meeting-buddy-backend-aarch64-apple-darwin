#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# --- Locate project root ---
if [ -n "${MEETINGBUDDY_PROJECT_ROOT:-}" ]; then
    PROJECT_ROOT="$MEETINGBUDDY_PROJECT_ROOT"
elif [[ "$SCRIPT_DIR" == *"/Contents/MacOS"* ]]; then
    # Running from .app bundle
    # .app is at <project>/ui/src-tauri/target/release/bundle/macos/Meeting Buddy.app
    # SCRIPT_DIR = .../Meeting Buddy.app/Contents/MacOS
    # From .app root: macos/ -> bundle/ -> release/ -> target/ -> src-tauri/ -> ui/ -> project
    APP_BUNDLE="$SCRIPT_DIR/../.."
    PROJECT_ROOT="$(cd "$APP_BUNDLE/../../../../../../.." 2>/dev/null && pwd)" || true
    if [ ! -f "$PROJECT_ROOT/backend/main.py" ]; then
        echo "ERROR: Cannot find project root (looked at $PROJECT_ROOT)." >&2
        echo "Set MEETINGBUDDY_PROJECT_ROOT env var to the Meeting Buddy repo root." >&2
        exit 1
    fi
else
    # Dev mode — script is at <project>/ui/src-tauri/
    PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
fi

# --- Locate AudioCapture binary ---
if [ -n "${MEETINGBUDDY_AUDIO_BINARY:-}" ]; then
    : # Already set by caller
elif [[ "$SCRIPT_DIR" == *"/Contents/MacOS"* ]]; then
    # Bundled alongside us in Contents/MacOS/
    export MEETINGBUDDY_AUDIO_BINARY="$SCRIPT_DIR/AudioCapture"
else
    # Dev mode — use the Swift build output
    export MEETINGBUDDY_AUDIO_BINARY="$PROJECT_ROOT/audio-capture/.build/release/AudioCapture"
fi

export MEETINGBUDDY_PROJECT_ROOT="$PROJECT_ROOT"

# --- Activate Python virtual environment ---
VENV="$PROJECT_ROOT/.venv"
if [ -f "$VENV/bin/activate" ]; then
    source "$VENV/bin/activate"
else
    echo "ERROR: Virtual environment not found at $VENV" >&2
    echo "Create it with: python3 -m venv .venv && pip install -r requirements.txt" >&2
    exit 1
fi

# --- Run the backend ---
cd "$PROJECT_ROOT"
exec python -m backend.main "$@"
